{
  "include": ["./**/*"],
  "compilerOptions": {
    "esModuleInterop": true,
    "skipLibCheck": true,
    "target": "es2022",
    "allowJs": true,
    "resolveJsonModule": true,
    "moduleDetection": "force",
    "isolatedModules": true,
    "verbatimModuleSyntax": true,
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,
    "module": "preserve",
    "noEmit": true,
    "jsx": "react-jsx",
    "jsxImportSource": "preact",
    "lib": ["es2022"],
    "paths": {
      "@/*": ["../*"]
    }
  }
}
