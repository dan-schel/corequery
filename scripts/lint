#!/bin/bash

set -euo pipefail

npx tsc -p server/tsconfig.json --noEmit
npx tsc -p web/tsconfig.json --noEmit
npx tsc -p tests/tsconfig.json --noEmit
npx tsc -p scripts/demo-app/tsconfig.json --noEmit
npx tsc -p scripts/generate-pwa-assets/tsconfig.json --noEmit

if [[ "${1:-}" == "--fix" ]]; then
  npx eslint . --max-warnings 0 --fix
else
  npx eslint . --max-warnings 0
fi

npx knip
